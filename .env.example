# ==============================================================================
# Environment Variable Template
# 
# [주의] 이 파일(.env.example)은 버전 관리에 포함됩니다.
# 실제 서비스의 비밀번호, API 키 등 민감한 정보는 절대 이곳에 하드코딩하지 마십시오.
# 
# [사용법] 로컬 개발 환경 세팅 시, 이 파일을 복사하여 `.env` 파일을 생성하십시오.
# $ cp .env.example .env
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Application Configuration (서버 구동 설정)
# ------------------------------------------------------------------------------
# 실행 환경 구분 (development | production | test)
NODE_ENV=development
# API 서버 포트 (기본값: 3000)
API_PORT=3000

# ------------------------------------------------------------------------------
# 2. Local Database Configuration (로컬 Docker Compose용)
# ------------------------------------------------------------------------------
# 로컬 PostgreSQL 초기화에 사용되는 관리자 계정 정보
POSTGRES_USER=local_admin_user
POSTGRES_PASSWORD=local_dummy_password
POSTGRES_DB=local_database_name

# ------------------------------------------------------------------------------
# 3. Database Connection String (ORM / 데이터베이스 드라이버용)
# ------------------------------------------------------------------------------
# [로컬 환경] docker-compose.yml의 서비스명(db)을 호스트로 사용
# 예시: postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}
# 
# [운영 환경 (Render + Neon)] Render 대시보드에서 동적으로 주입되므로 로컬에서만 덮어씀
DATABASE_URL=postgres://user:password@host:port/dbname

# ------------------------------------------------------------------------------
# 4. Security & Authentication (인증 및 보안 설정 - 예비)
# ------------------------------------------------------------------------------
# CORS 허용 출처 (쉼표로 여러 출처 지정 가능)
CORS_ORIGIN=http://localhost:3000,https://webfull-9-10-sabujak-fe.vercel.app

# ------------------------------------------------------------------------------
# 5. Docker Development Optimization (OS 호환성 최적화)
# ------------------------------------------------------------------------------
# Windows / WSL2 환경에서 도커 핫리로드가 작동하지 않을 경우 아래 값을 true로 변경하십시오.
# Mac 사용자이거나 핫리로드가 정상 작동하는 경우 성능(CPU 최적화)을 위해 false를 유지하십시오.
CHOKIDAR_USEPOLLING=false

