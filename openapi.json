{
  "openapi": "3.0.0",
  "info": {
    "title": "Sabujak API",
    "version": "1.0.0",
    "description": "사부작 백엔드 API 문서입니다."
  },
  "servers": [
    {
      "url": "/"
    }
  ],
  "components": {
    "schemas": {
      "SlugReservationResponse": {
        "type": "object",
        "properties": {
          "slug": {
            "type": "string",
            "minLength": 1,
            "maxLength": 50,
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
            "description": "사용자 노출용 slug 식별자",
            "example": "our-graduation-2025"
          },
          "reservationToken": {
            "type": "string",
            "example": "01HQX7Y8J6R8J2E5W4C2R9A1BC"
          },
          "reservedUntil": {
            "type": "string",
            "format": "date-time",
            "example": "2026-03-18T02:10:21.000Z"
          }
        },
        "required": ["slug", "reservationToken", "reservedUntil"]
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "code": {
                "type": "string",
                "enum": [
                  "INVALID_INPUT",
                  "FORBIDDEN_PASSWORD",
                  "CAPSULE_NOT_FOUND",
                  "SLUG_ALREADY_IN_USE",
                  "SLUG_RESERVATION_MISMATCH",
                  "DUPLICATE_NICKNAME",
                  "MESSAGE_LIMIT_EXCEEDED",
                  "CAPSULE_EXPIRED",
                  "CAPSULE_ALREADY_OPENED",
                  "TOO_MANY_REQUESTS",
                  "INTERNAL_SERVER_ERROR"
                ]
              },
              "message": {
                "type": "string"
              },
              "details": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/ErrorDetail"
                },
                "description": "입력값 검증 실패 시 필드별 상세 오류 목록",
                "example": [
                  {
                    "field": "title",
                    "message": "최소 1자 이상이어야 합니다."
                  },
                  {
                    "field": "password",
                    "message": "4자리 숫자여야 합니다."
                  }
                ]
              }
            },
            "required": ["code", "message"]
          }
        },
        "required": ["error"]
      },
      "ErrorDetail": {
        "type": "object",
        "properties": {
          "field": {
            "type": "string",
            "description": "유효성 검사에 실패한 필드 경로",
            "example": "title"
          },
          "message": {
            "type": "string",
            "description": "해당 필드의 검증 실패 메시지",
            "example": "최소 1자 이상이어야 합니다."
          }
        },
        "required": ["field", "message"]
      },
      "CreateSlugReservationRequest": {
        "type": "object",
        "properties": {
          "slug": {
            "type": "string",
            "minLength": 1,
            "maxLength": 50,
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
            "description": "사용자 노출용 slug 식별자",
            "example": "our-graduation-2025"
          }
        },
        "required": ["slug"]
      },
      "CreateCapsuleResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "01ARZ3NDEKTSV4RRFFQ69G5FAV"
          },
          "slug": {
            "type": "string",
            "minLength": 1,
            "maxLength": 50,
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
            "description": "사용자 노출용 slug 식별자",
            "example": "our-graduation-2025"
          },
          "title": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100,
            "example": "졸업 축하 타임캡슐"
          },
          "openAt": {
            "type": "string",
            "format": "date-time",
            "example": "2025-12-25T12:00:00.000Z"
          },
          "expiresAt": {
            "type": "string",
            "format": "date-time",
            "example": "2026-01-01T12:00:00.000Z"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "example": "2025-03-18T02:05:21.000Z"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time",
            "example": "2025-03-18T02:05:21.000Z"
          }
        },
        "required": [
          "id",
          "slug",
          "title",
          "openAt",
          "expiresAt",
          "createdAt",
          "updatedAt"
        ]
      },
      "CreateCapsuleRequest": {
        "type": "object",
        "properties": {
          "slug": {
            "type": "string",
            "minLength": 1,
            "maxLength": 50,
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
            "description": "사용자 노출용 slug 식별자",
            "example": "our-graduation-2025"
          },
          "title": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100,
            "example": "졸업 축하 타임캡슐"
          },
          "password": {
            "type": "string",
            "pattern": "^\\d{4}$",
            "example": "1234"
          },
          "openAt": {
            "type": "string",
            "format": "date-time",
            "example": "2025-12-25T12:00:00.000Z"
          },
          "reservationToken": {
            "type": "string",
            "example": "01HQX7Y8J6R8J2E5W4C2R9A1BC"
          }
        },
        "required": ["slug", "title", "password", "openAt", "reservationToken"]
      },
      "CapsuleDetailResponse": {
        "oneOf": [
          {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "example": "01ARZ3NDEKTSV4RRFFQ69G5FAV"
              },
              "slug": {
                "type": "string",
                "minLength": 1,
                "maxLength": 50,
                "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
                "description": "사용자 노출용 slug 식별자",
                "example": "our-graduation-2025"
              },
              "title": {
                "type": "string",
                "minLength": 1,
                "maxLength": 100,
                "example": "졸업 축하 타임캡슐"
              },
              "openAt": {
                "type": "string",
                "format": "date-time",
                "example": "2025-12-25T12:00:00.000Z"
              },
              "expiresAt": {
                "type": "string",
                "format": "date-time",
                "example": "2026-01-01T12:00:00.000Z"
              },
              "createdAt": {
                "type": "string",
                "format": "date-time",
                "example": "2025-03-18T02:05:21.000Z"
              },
              "updatedAt": {
                "type": "string",
                "format": "date-time",
                "example": "2025-03-18T02:05:21.000Z"
              },
              "isOpen": {
                "type": "boolean",
                "enum": [false],
                "example": false
              },
              "messageCount": {
                "type": "integer",
                "example": 12
              }
            },
            "required": [
              "id",
              "slug",
              "title",
              "openAt",
              "expiresAt",
              "createdAt",
              "updatedAt",
              "isOpen",
              "messageCount"
            ]
          },
          {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "example": "01ARZ3NDEKTSV4RRFFQ69G5FAV"
              },
              "slug": {
                "type": "string",
                "minLength": 1,
                "maxLength": 50,
                "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
                "description": "사용자 노출용 slug 식별자",
                "example": "our-graduation-2025"
              },
              "title": {
                "type": "string",
                "minLength": 1,
                "maxLength": 100,
                "example": "졸업 축하 타임캡슐"
              },
              "openAt": {
                "type": "string",
                "format": "date-time",
                "example": "2025-12-25T12:00:00.000Z"
              },
              "expiresAt": {
                "type": "string",
                "format": "date-time",
                "example": "2026-01-01T12:00:00.000Z"
              },
              "createdAt": {
                "type": "string",
                "format": "date-time",
                "example": "2025-03-18T02:05:21.000Z"
              },
              "updatedAt": {
                "type": "string",
                "format": "date-time",
                "example": "2025-06-01T10:00:00.000Z"
              },
              "isOpen": {
                "type": "boolean",
                "enum": [true],
                "example": true
              },
              "messageCount": {
                "type": "integer",
                "example": 5
              },
              "messages": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/CapsuleMessage"
                },
                "description": "공개 후 내려오는 메시지 목록"
              }
            },
            "required": [
              "id",
              "slug",
              "title",
              "openAt",
              "expiresAt",
              "createdAt",
              "updatedAt",
              "isOpen",
              "messageCount",
              "messages"
            ]
          }
        ]
      },
      "CapsuleMessage": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "example": 1
          },
          "nickname": {
            "type": "string",
            "example": "익명의 멘토"
          },
          "content": {
            "type": "string",
            "example": "졸업을 진심으로 축하합니다!"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "example": "2025-12-24T15:30:00.000Z"
          }
        },
        "required": ["id", "nickname", "content", "createdAt"]
      },
      "VerifyCapsulePasswordResponse": {
        "type": "object",
        "properties": {
          "verified": {
            "type": "boolean",
            "example": true
          }
        },
        "required": ["verified"]
      },
      "VerifyCapsulePasswordRequest": {
        "type": "object",
        "properties": {
          "password": {
            "type": "string",
            "pattern": "^\\d{4}$",
            "example": "1234"
          }
        },
        "required": ["password"]
      },
      "UpdateCapsuleResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "01ARZ3NDEKTSV4RRFFQ69G5FAV"
          },
          "slug": {
            "type": "string",
            "minLength": 1,
            "maxLength": 50,
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
            "description": "사용자 노출용 slug 식별자",
            "example": "our-graduation-2025"
          },
          "title": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100,
            "example": "졸업 축하 타임캡슐"
          },
          "openAt": {
            "type": "string",
            "format": "date-time",
            "example": "2025-12-25T12:00:00.000Z"
          },
          "expiresAt": {
            "type": "string",
            "format": "date-time",
            "example": "2026-01-01T12:00:00.000Z"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "example": "2025-03-18T02:05:21.000Z"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time",
            "example": "2025-03-18T02:05:21.000Z"
          }
        },
        "required": [
          "id",
          "slug",
          "title",
          "openAt",
          "expiresAt",
          "createdAt",
          "updatedAt"
        ]
      },
      "UpdateCapsuleRequest": {
        "type": "object",
        "properties": {
          "password": {
            "type": "string",
            "pattern": "^\\d{4}$",
            "example": "1234"
          },
          "title": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100,
            "example": "졸업 축하 타임캡슐"
          },
          "openAt": {
            "type": "string",
            "format": "date-time",
            "example": "2025-12-25T12:00:00.000Z"
          }
        },
        "required": ["password", "title", "openAt"]
      },
      "DeleteCapsuleRequest": {
        "type": "object",
        "properties": {
          "password": {
            "type": "string",
            "pattern": "^\\d{4}$",
            "example": "1234"
          }
        },
        "required": ["password"]
      },
      "CreateMessageResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "example": 13
          },
          "nickname": {
            "type": "string",
            "minLength": 1,
            "maxLength": 20,
            "example": "익명의 친구"
          },
          "content": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1000,
            "example": "앞으로도 좋은 일만 가득하길 바랄게!"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "example": "2025-03-18T02:05:21.000Z"
          }
        },
        "required": ["id", "nickname", "content", "createdAt"]
      },
      "CreateMessageRequest": {
        "type": "object",
        "properties": {
          "nickname": {
            "type": "string",
            "minLength": 1,
            "maxLength": 20,
            "example": "익명의 친구"
          },
          "content": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1000,
            "example": "앞으로도 좋은 일만 가득하길 바랄게!"
          }
        },
        "required": ["nickname", "content"]
      }
    },
    "parameters": {}
  },
  "paths": {
    "/capsules/slug-reservations": {
      "post": {
        "tags": ["Capsule"],
        "summary": "슬러그 예약 생성❤️",
        "description": "중복 확인 후 슬러그 예약 토큰을 발급합니다.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateSlugReservationRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "슬러그 예약 생성 성공",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SlugReservationResponse"
                }
              }
            }
          },
          "400": {
            "description": "INVALID_INPUT",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "examples": {
                  "invalid_input": {
                    "value": {
                      "error": {
                        "code": "INVALID_INPUT",
                        "message": "요청 값을 확인해 주세요."
                      }
                    }
                  }
                }
              }
            }
          },
          "409": {
            "description": "SLUG_ALREADY_IN_USE",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "examples": {
                  "slug_already_in_use": {
                    "value": {
                      "error": {
                        "code": "SLUG_ALREADY_IN_USE",
                        "message": "이미 사용 중인 slug 입니다."
                      }
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "INTERNAL_SERVER_ERROR",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "examples": {
                  "internal_server_error": {
                    "value": {
                      "error": {
                        "code": "INTERNAL_SERVER_ERROR",
                        "message": "서버 내부 오류가 발생했습니다."
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/capsules": {
      "post": {
        "tags": ["Capsule"],
        "summary": "캡슐 생성❤️",
        "description": "예약 토큰을 검증한 뒤 신규 타임캡슐을 생성하고, openAt 기준으로 expiresAt을 계산합니다.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateCapsuleRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "캡슐 생성 성공",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateCapsuleResponse"
                }
              }
            }
          },
          "400": {
            "description": "INVALID_INPUT",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "examples": {
                  "invalid_input": {
                    "value": {
                      "error": {
                        "code": "INVALID_INPUT",
                        "message": "요청 값을 확인해 주세요."
                      }
                    }
                  }
                }
              }
            }
          },
          "409": {
            "description": "SLUG_RESERVATION_MISMATCH | SLUG_ALREADY_IN_USE",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "examples": {
                  "slug_reservation_mismatch": {
                    "value": {
                      "error": {
                        "code": "SLUG_RESERVATION_MISMATCH",
                        "message": "slug 예약 토큰 검증에 실패했습니다."
                      }
                    }
                  },
                  "slug_already_in_use": {
                    "value": {
                      "error": {
                        "code": "SLUG_ALREADY_IN_USE",
                        "message": "이미 사용 중인 slug 입니다."
                      }
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "INTERNAL_SERVER_ERROR",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "examples": {
                  "internal_server_error": {
                    "value": {
                      "error": {
                        "code": "INTERNAL_SERVER_ERROR",
                        "message": "서버 내부 오류가 발생했습니다."
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/capsules/{slug}": {
      "get": {
        "tags": ["Capsule"],
        "summary": "캡슐 조회❤️",
        "description": "공개 전/후 상태에 따라 캡슐 기본 정보와 메시지 목록을 조회합니다.",
        "parameters": [
          {
            "schema": {
              "type": "string",
              "minLength": 1,
              "maxLength": 50,
              "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
              "description": "사용자 노출용 slug 식별자",
              "example": "our-graduation-2025"
            },
            "required": true,
            "description": "조회/수정/삭제 대상 캡슐의 slug",
            "name": "slug",
            "in": "path"
          }
        ],
        "responses": {
          "200": {
            "description": "공개 전 또는 공개 후 캡슐 응답",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CapsuleDetailResponse"
                },
                "examples": {
                  "closed": {
                    "summary": "공개 전 예시",
                    "value": {
                      "id": "01ARZ3NDEKTSV4RRFFQ69G5FAV",
                      "slug": "our-graduation-2025",
                      "title": "졸업 축하 타임캡슐",
                      "openAt": "2025-12-25T12:00:00.000Z",
                      "expiresAt": "2026-01-01T12:00:00.000Z",
                      "createdAt": "2025-03-18T02:05:21.000Z",
                      "updatedAt": "2025-03-18T02:05:21.000Z",
                      "isOpen": false,
                      "messageCount": 12
                    }
                  },
                  "opened": {
                    "summary": "공개 후 예시",
                    "value": {
                      "id": "01ARZ3NDEKTSV4RRFFQ69G5FAV",
                      "slug": "opened-capsule",
                      "title": "졸업 축하 타임캡슐",
                      "openAt": "2025-12-25T12:00:00.000Z",
                      "expiresAt": "2026-01-01T12:00:00.000Z",
                      "createdAt": "2025-03-18T02:05:21.000Z",
                      "updatedAt": "2025-06-01T10:00:00.000Z",
                      "isOpen": true,
                      "messageCount": 5,
                      "messages": [
                        {
                          "id": 1,
                          "nickname": "익명의 멘토",
                          "content": "졸업을 진심으로 축하합니다!",
                          "createdAt": "2025-12-24T15:30:00.000Z"
                        }
                      ]
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "CAPSULE_NOT_FOUND",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "examples": {
                  "capsule_not_found": {
                    "value": {
                      "error": {
                        "code": "CAPSULE_NOT_FOUND",
                        "message": "존재하지 않는 캡슐입니다."
                      }
                    }
                  }
                }
              }
            }
          },
          "410": {
            "description": "CAPSULE_EXPIRED",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "examples": {
                  "capsule_expired": {
                    "value": {
