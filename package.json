{
  "name": "sabujak",
  "version": "1.0.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "rm -rf dist && tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.scripts.json",
    "lint": "eslint \"src/**/*.ts\" --no-error-on-unmatched-pattern",
    "lint:fix": "eslint \"src/**/*.ts\" --fix --no-error-on-unmatched-pattern",
    "openapi:generate": "node --import tsx scripts/generate-openapi.ts",
    "openapi:check": "node --import tsx scripts/check-openapi.ts",
    "prepare": "husky",
    "test:rate-limit": "bash scripts/test-rate-limit.sh"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix --no-error-on-unmatched-pattern",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-rate-limit": "^6.0.2",
    "@types/node": "^20.19.37",
    "@types/pg": "^8.18.0",
    "@types/swagger-ui-express": "^4.1.8",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "husky": "^9.x.x",
    "lint-staged": "^15.x.x",
    "prettier": "^3.x.x",
    "tsx": "^4.21.0",
    "typescript": "^5.x.x",
    "typescript-eslint": "^8.57.0"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.4.3",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "pg": "^8.20.0",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.3.6"
  }
}
