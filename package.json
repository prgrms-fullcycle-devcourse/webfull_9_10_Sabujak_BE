{
  "name": "sabujak",
  "version": "1.0.0",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0 <10.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "rm -rf dist && tsc",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.scripts.json",
    "lint": "eslint \"src/**/*.ts\" --no-error-on-unmatched-pattern",
    "lint:fix": "eslint \"src/**/*.ts\" --fix --no-error-on-unmatched-pattern",
    "test": "jest --runInBand",
    "test:unit": "jest --runInBand",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config drizzle.config.ts",
    "db:schema:export": "node --import tsx scripts/export-db-schema-reference.ts",
    "db:schema:check": "node --import tsx scripts/check-db-schema.ts",
    "db:repair:legacy-drift": "node --import tsx scripts/repair-db-drift.ts",
    "openapi:generate": "node --import tsx scripts/generate-openapi.ts",
    "openapi:check": "node --import tsx scripts/check-openapi.ts",
    "batch:expire": "node --import tsx scripts/expire-capsules.ts",
    "db:backfill:original-slug": "node --import tsx scripts/backfill-original-slug.ts",
    "prepare": "husky",
    "test:rate-limit": "bash scripts/test-rate-limit.sh",
    "pr-review:prepare": "bash scripts/generate-pr-review-input.sh",
    "pr-review:open": "bash scripts/open-pr-review.sh",
    "pr-review:open:quick": "bash scripts/open-pr-review.sh --mode quick",
    "pr-review:open:deep": "bash scripts/open-pr-review.sh --mode deep",
    "pr-review:save": "bash scripts/save-pr-review.sh"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix --no-error-on-unmatched-pattern",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-rate-limit": "^6.0.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.19.37",
    "@types/pg": "^8.18.0",
    "@types/pino-http": "^6.1.0",
    "@types/swagger-ui-express": "^4.1.8",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "husky": "^9.x.x",
    "jest": "^30.3.0",
    "lint-staged": "^15.x.x",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.x.x",
    "ts-jest": "^29.4.6",
    "tsx": "^4.21.0",
    "typescript": "^5.x.x",
    "typescript-eslint": "^8.57.0"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.4.3",
    "@sentry/node": "^10.47.0",
    "@sentry/profiling-node": "^10.47.0",
    "@upstash/redis": "^1.37.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "redis": "^5.11.0",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.3.6"
  },
  "pnpm": {
    "overrides": {
      "yaml": "^2.8.3",
      "path-to-regexp": ">=8.4.0",
      "brace-expansion": ">=5.0.5"
    }
  }
}
